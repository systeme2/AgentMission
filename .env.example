# =============================================================
# .env.example — Mission Agent v2
# Copie en .env et remplis les valeurs
# =============================================================

# ── Telegram (obligatoire) ────────────────────────────────────
# 1. Crée ton bot : @BotFather → /newbot
# 2. Récupère le token
TELEGRAM_TOKEN=1234567890:ABCdefGhIJKlmNoPQRstuVWXyz

# 3. Récupère ton chat_id :
#    Envoie un message à ton bot, puis :
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    Cherche "chat":{"id": XXXXXXX}
TELEGRAM_CHAT_ID=123456789

# ── OpenAI (optionnel — améliore l'analyse + active les embeddings) ──
OPENAI_API_KEY=sk-...

# ── Profil actif ──────────────────────────────────────────────
# Valeurs : all | wordpress | react | seo | international
# all = comportement généraliste (défaut)
ACTIVE_PROFILE=all

# ── Bot Telegram bidirectionnel ───────────────────────────────
# true = polling actif en parallèle (commandes /stats /top5 /pause etc.)
# false = notifications uniquement, sans bot interactif
TELEGRAM_BOT_ENABLED=true

# ── Scoring sémantique (embeddings) ──────────────────────────
# true = utilise OpenAI text-embedding-3-small pour un bonus de score
# Nécessite OPENAI_API_KEY. Fallback automatique si absent.
SEMANTIC_SCORING=true

# ── Profil idéal pour les embeddings (optionnel) ─────────────
# Texte libre décrivant ce que tu recherches.
# Si vide → auto-généré depuis PREFERRED_KEYWORDS dans settings.py
# Exemple :
# IDEAL_PROFILE_TEXT=Expert WordPress senior, spécialiste WooCommerce et refonte de sites vitrines. Remote uniquement. Budget minimum 400€.
IDEAL_PROFILE_TEXT=

# ── Twitter/X (optionnel) ─────────────────────────────────────
# Crée une app sur developer.twitter.com (tier gratuit)
# Sans token → fallback Nitter RSS automatique
TWITTER_BEARER_TOKEN=

# ── GitHub (optionnel) ────────────────────────────────────────
# Sans token : 60 req/h (suffisant pour usage personnel)
# Avec token : 5000 req/h
# Crée un token sur github.com/settings/tokens (scope: public_repo)
GITHUB_TOKEN=

# =============================================================
# CUSTOM_RSS_FEEDS : à configurer dans config/settings.py
#
# PREFERRED_KEYWORDS, NEGATIVE_KEYWORDS, MIN_BUDGET, MIN_SCORE
# → configurables dans config/settings.py
# =============================================================

# ── Chargement ────────────────────────────────────────────────
# Linux/Mac : export $(cat .env | grep -v '^#' | xargs)
# Ou avec python-dotenv (auto si installé) :
#   from dotenv import load_dotenv; load_dotenv()
